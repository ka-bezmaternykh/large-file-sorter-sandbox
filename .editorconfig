root = true

# Default settings for all files
[*]
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf
charset = utf-8

# C# specific rules
[*.cs]
csharp_prefer_braces = true:suggestion
csharp_new_line_before_open_brace = all

# Json specific rules
[*.json]
indent_style = space
indent_size = 2